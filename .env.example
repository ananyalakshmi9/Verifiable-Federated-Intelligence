# -------------------------------------------------------------
# Zero-Knowledge Blockchain & Cryptographic Settings
# -------------------------------------------------------------
# Polygon Amoy RPC URL (Get from Alchemy, Infura, or public)
POLYGON_AMOY_RPC_URL="https://rpc-amoy.polygon.technology/"

# Wallet private key for deploying and calling the AMLVerifier (DO NOT SHARE)
PRIVATE_KEY="your_wallet_private_key_here"

# -------------------------------------------------------------
# Application Logging Settings
# -------------------------------------------------------------
LOG_LEVEL="INFO" # Options: DEBUG, INFO, WARNING, ERROR

# -------------------------------------------------------------
# ZKP Circom Circuit Constraints
# -------------------------------------------------------------
# Threshold constraint for maximum allowable weight magnitude distortion
ZKP_MAGNITUDE_THRESHOLD="0.5"
